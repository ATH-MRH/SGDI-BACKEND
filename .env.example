APP_NAME=SGDI FastAPI Backend
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO
API_PREFIX=/api
ALLOW_PUBLIC_REGISTRATION=false

DATABASE_URL=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=720
ADMIN_INITIAL_USERNAME=
ADMIN_INITIAL_PASSWORD=
ADMIN_SYSTEM_USERNAME=
ADMIN_SYSTEM_PASSWORD=

# Assistant ATLAS local par défaut. Mettre true uniquement si vous voulez utiliser l'IA payante.
ASSISTANT_PAID_AI_ENABLED=false
# Assistant IA payant optionnel — obtenir sur https://console.anthropic.com
ANTHROPIC_API_KEY=

# Alertes email automatiques pour les fins de contrat
CONTRACT_EMAIL_ALERTS_ENABLED=true
CONTRACT_EMAIL_ALERT_WINDOW_DAYS=30
CONTRACT_EMAIL_ALERT_DAYS=
CONTRACT_EMAIL_ALERT_RECIPIENTS=
CONTRACT_EMAIL_ALERT_INTERVAL_HOURS=24
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=SGDI
SMTP_USE_TLS=true
SMTP_USE_SSL=false
