# Obligatoire : URL de la base PostgreSQL persistante du serveur.
# Exemple : postgresql+psycopg2://sgdi:mot_de_passe@postgres:5432/sgdi
DATABASE_URL=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
JWT_SECRET=
ADMIN_INITIAL_USERNAME=
ADMIN_INITIAL_PASSWORD=
ADMIN_SYSTEM_USERNAME=
ADMIN_SYSTEM_PASSWORD=

# Optional overrides
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO
JWT_EXPIRES_MINUTES=720
CORS_ALLOWED_ORIGINS=
STARTUP_MAINTENANCE_ENABLED=false
PUBLIC_EMPLOYEE_PAGES_REQUIRE_TOKEN=true
MAX_PHOTO_UPLOAD_BYTES=5000000

# Performance : nombre de workers Gunicorn. Vide = valeur par défaut de gunicorn.conf.py.
WEB_CONCURRENCY=
# Répertoire persistant des photos/fichiers (monté sur volume dans docker-compose).
SGDI_UPLOADS_DIR=/app/uploads
# Noms d'hôte servant le Portail RH (virgule). Ajouter le sous-domaine de test au besoin.
# Ex. staging : portail-rh.irongs.com,portail-rh-test.irongs.com
PORTAL_HOSTNAMES=portail-rh.irongs.com
# CORS : origines autorisées (virgule). En staging, inclure les sous-domaines de test.
# Ex. : https://test.irongs.com,https://portail-rh-test.irongs.com
CORS_ALLOWED_ORIGINS=

# Cloudflare Tunnel (exposition HTTPS sans ouverture de port). Token du dashboard Zero Trust.
# Requis uniquement si vous lancez le profil : docker compose --profile tunnel up -d
CLOUDFLARE_TUNNEL_TOKEN=

# Agent IA ATLAS (Phase 1 : lecture seule). Mettre true + fournir la clé pour activer.
# La clé se met dans l'environnement du serveur (Coolify), jamais dans le code/git.
ASSISTANT_AGENT_ENABLED=false
ANTHROPIC_API_KEY=
ASSISTANT_AGENT_MODEL=claude-opus-4-8
# Repli automatique sur un modèle local (Ollama) si Claude echoue / facturation.
ASSISTANT_FALLBACK_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b

# Alertes email automatiques pour les fins de contrat
CONTRACT_EMAIL_ALERTS_ENABLED=true
CONTRACT_EMAIL_ALERT_WINDOW_DAYS=30
CONTRACT_EMAIL_ALERT_DAYS=
CONTRACT_EMAIL_ALERT_RECIPIENTS=
CONTRACT_EMAIL_ALERT_INTERVAL_HOURS=24
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=SGDI
SMTP_USE_TLS=true
SMTP_USE_SSL=false
